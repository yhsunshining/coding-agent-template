{
  "name": "coding-agent-template",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter @coder/web dev",
    "dev:server": "pnpm --filter @coder/server dev",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "pnpm --filter @coder/web build",
    "build:server": "pnpm --filter @coder/server build",
    "start": "pnpm --filter @coder/server start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "setup:tcr": "node scripts/setup-tcr.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cloudbase/node-sdk": "^3.18.1",
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/ms": "^2.1.0",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.36.4",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tencentcloud-sdk-nodejs": "^4.1.205",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all"
  },
  "pnpm": {
    "patchedDependencies": {
      "@tencent-ai/agent-sdk@0.3.68": "patches/@tencent-ai__agent-sdk@0.3.68.patch"
    }
  },
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd"
}
