{
  "name": "coding-agent-template",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter @coder/web dev",
    "dev:server": "pnpm --filter @coder/server dev",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "pnpm --filter @coder/web build",
    "build:server": "pnpm --filter @coder/server build",
    "start": "pnpm --filter @coder/server start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "setup:tcr": "node scripts/setup-tcr.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.55",
    "@cloudbase/manager-node": "^4.10.6",
    "@cloudbase/node-sdk": "^3.18.1",
    "@cloudbase/toolbox": "^0.7.19",
    "@git-diff-view/file": "^0.0.32",
    "@git-diff-view/react": "^0.0.32",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tencent-ai/agent-sdk": "0.3.68",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-cookie": "^3.0.6",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/sandbox": "^0.0.21",
    "@vercel/sdk": "^1.18.7",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "5.0.51",
    "arctic": "^3.7.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.36.4",
    "jose": "^6.1.3",
    "jotai": "^2.16.2",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.544.0",
    "ms": "^2.1.3",
    "nanoid": "^5.1.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sonner": "^2.0.7",
    "streamdown": "^1.6.11",
    "tailwind-merge": "^3.4.0",
    "typescript-language-server": "^5.1.3",
    "uuid": "^13.0.0",
